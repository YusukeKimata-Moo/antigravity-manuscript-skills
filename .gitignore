# manuscript-skills: repo-specific ignore rules
# This repository currently tracks Markdown skill definitions and references.
# Keep the ignore set minimal and focused on local/editor-generated files.

# OS-generated files
.DS_Store
Thumbs.db
Desktop.ini

# Editor / IDE settings
.vscode/
.idea/
*.code-workspace

# Swap, backup, and patch leftovers
*.swp
*.swo
*~
\#*\#
*.orig
*.rej

# Local agent runtime / test-install directories
.agent/
.agents/

# Local logs
*.log

# Optional: uncomment only if you decide to stop tracking the generated guideline snapshot in this repo.
# Note: .gitignore does not affect files that are already tracked by Git.
shared-references/journal_guidelines.md
